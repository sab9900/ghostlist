# ─── Standalone (docker-compose.yml) ─────────────────────────────────────────
# Used when GhostList manages its own PostgreSQL container.
POSTGRES_DB=ghostlist
POSTGRES_USER=ghostlist
POSTGRES_PASSWORD=changeme

# ─── External DB (docker-compose.external-db.yml) ────────────────────────────
# Used when connecting to an existing PostgreSQL instance (e.g. Coolify).
# Npgsql format: Host=<host>;Database=<db>;Username=<user>;Password=<pass>
DB_CONNECTION_STRING=Host=localhost;Database=ghostlist;Username=ghostlist;Password=changeme

# ─── Admin dashboard (admin-client, admin.ghost-list.com) ────────────────────
# Basic Auth credentials for the /api/admin/* endpoints and the admin UI.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ─── Firebase Cloud Messaging (push notifications) ───────────────────────────
# Paste the FULL content of the Firebase service account JSON file as a single
# line (the Firebase Admin SDK private key for project ghostlist-ff00f).
# Get it from: Firebase Console > Project Settings > Service Accounts > Generate new private key
FCM_CREDENTIALS_JSON={"type":"service_account","project_id":"ghostlist-ff00f", ...}
