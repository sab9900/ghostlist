{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/favicon.svg",
          "/favicon-96x96.png",
          "/apple-touch-icon.png",
          "/index.html",
          "/site.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/ghost-header.svg",
          "/web-app-manifest-192x192.png",
          "/web-app-manifest-512x512.png"
        ]
      }
    }
  ]
}
