{
  "name": "ghost-list-client",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-version.js",
    "start": "ng serve",
    "prebuild": "node scripts/generate-version.js",
    "build": "ng build",
    "build:cap": "ng build --configuration production && npx cap sync",
    "ios": "ng build --configuration production && npx cap sync ios && npx cap open ios",
    "android": "ng build --configuration production && npx cap sync android && npx cap open android",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "^22.0.0",
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@microsoft/signalr": "^10.0.0",
    "firebase": "^12.14.0",
    "@ngrx/signals": "^21.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "jsqr": "^1.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@capacitor/cli": "^7.0.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
